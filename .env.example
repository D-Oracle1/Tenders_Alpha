# Database
DATABASE_URL="postgresql://user:password@localhost:5432/tenders_db"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"
JWT_EXPIRES_IN="7d"

# Admin
ADMIN_EMAIL="admin@tendersgeneralmerchant.com"
ADMIN_PASSWORD="Admin@123456"

# Next.js
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-key"

# Supabase (storage + optional DB)
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""
# File uploads use Supabase Storage when the above vars are set, local disk otherwise

# Email (Nodemailer)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="tendersgeneralmerchant@gmail.com"
SMTP_PASS=""
SMTP_FROM="Tenders Alpha <tendersgeneralmerchant@gmail.com>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COMPANY_NAME="Tenders Alpha"
